# Database connection settings
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_INSECURE_AUTH=false
DB_MULTIPLE_STATEMENTS=false

# Optional: require this token for POST/PUT/PATCH/DELETE requests.
# Send it as X-ITS-Auth-Token, Authorization: Bearer <token>, cookie its_auth_token,
# or authToken query parameter.
ITS_AUTH_TOKEN=

# Set PORT for each server if needed, e.g.
# PORT=3003
